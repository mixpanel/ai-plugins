#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[0;33m'
BOLD='\033[1m'
RESET='\033[0m'

source_changed=$(git diff --cached --name-only -- plugins/mixpanel-mcp/skills/ | head -1)
eu_changed=$(git diff --cached --name-only -- plugins/mixpanel-mcp-eu/skills/ | head -1)
in_changed=$(git diff --cached --name-only -- plugins/mixpanel-mcp-in/skills/ | head -1)

if [ -n "$eu_changed" ] || [ -n "$in_changed" ]; then
    if [ -z "$source_changed" ]; then
        echo ""
        echo -e "${RED}${BOLD}ERROR:${RESET} Don't edit skills in \`mixpanel-mcp-eu\` or \`mixpanel-mcp-in\` only."
        echo ""
        echo -e "  ${BOLD}plugins/mixpanel-mcp/skills${RESET} is the source of truth."
        echo -e "  Edit skills there, then run ${YELLOW}make sync-skills${RESET} to propagate."
        echo -e "  To skip this check: ${YELLOW}git commit -n -m 'commit message'${RESET}"
        echo ""
        exit 1
    fi
fi
