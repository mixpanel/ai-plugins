#!/usr/bin/env bash
set -euo pipefail

# Check if staged files include mixpanel-mcp-eu or mixpanel-mcp-in skills
# but NOT the mixpanel-mcp source.
source_changed=$(git diff --cached --name-only -- plugins/mixpanel-mcp/skills/ | head -1)
eu_changed=$(git diff --cached --name-only -- plugins/mixpanel-mcp-eu/skills/ | head -1)
in_changed=$(git diff --cached --name-only -- plugins/mixpanel-mcp-in/skills/ | head -1)

if [ -n "$eu_changed" ] || [ -n "$in_changed" ]; then
    if [ -z "$source_changed" ]; then
        echo "ERROR: You are committing changes to mixpanel-mcp-eu/mixpanel-mcp-in skills without changing the source."
        echo ""
        echo "plugins/mixpanel-mcp/skills/ is the source of truth."
        echo "Edit skills there, then run 'make sync-skills' to propagate."
        exit 1
    fi
fi
